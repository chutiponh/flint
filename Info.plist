<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Standard bundle metadata driven by build-setting variables -->
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleName</key>
	<string>Flint</string>
	<key>CFBundleDisplayName</key>
	<string>Flint</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>

	<!-- App posture (migrated from INFOPLIST_KEY_* build settings) -->
	<key>LSApplicationCategoryType</key>
	<string>public.app-category.developer-tools</string>
	<!-- Menubar/no-Dock app (was INFOPLIST_KEY_LSUIElement=1) -->
	<key>LSUIElement</key>
	<true/>
	<key>LSBackgroundOnly</key>
	<false/>
	<key>NSHumanReadableCopyright</key>
	<string></string>
	<key>NSPrincipalClass</key>
	<string>NSApplication</string>

	<!-- DIST-04: Sparkle auto-update keys (plan 03-03).
	     CRITICAL: SUPublicEDKey MUST be present in the FIRST distributed build. If Flint
	     ever ships a release without this key, Sparkle rejects adding it later as a security
	     downgrade and locks every existing user out of auto-update PERMANENTLY
	     (RESEARCH Pitfall #5 / SUMMARY Pitfall #10).

	     ============================ PLACEHOLDER — MUST REPLACE ============================
	     The value below is a NON-FUNCTIONAL PLACEHOLDER, not a real EdDSA public key. The real
	     key is produced by running Sparkle 2.9.3's `bin/generate_keys` ONCE (plan 03-05), which
	     prints the public key here and stores the matching PRIVATE key in the login Keychain.
	     Before ANY release build ships, replace this with the real base64 public key from
	     generate_keys and verify with:
	         /usr/libexec/PlistBuddy -c "Print :SUPublicEDKey" Info.plist
	     Do NOT ship with this placeholder. (Deferred to plan 03-05 — credential-gated.)
	     =================================================================================== -->
	<key>SUPublicEDKey</key>
	<string>PLACEHOLDER_REPLACE_WITH_REAL_SUPublicEDKey_FROM_generate_keys_BEFORE_RELEASE_03-05</string>

	<!-- SUFeedURL: appcast location. PLACEHOLDER local/staging URL for the v0.0.1→v0.0.2
	     local dry-run (plan 03-05). MUST be replaced with the production HTTPS appcast URL
	     before the real v1.0 release (T-03-08: feed URL is hardcoded, not user-configurable). -->
	<key>SUFeedURL</key>
	<string>http://localhost:8000/appcast.xml</string>

</dict>
</plist>

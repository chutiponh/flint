<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Standard bundle metadata driven by build-setting variables -->
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<!-- CFBundleName MUST match NSServices NSPortName ("Flint") -->
	<key>CFBundleName</key>
	<string>Flint</string>
	<key>CFBundleDisplayName</key>
	<string>Flint</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>

	<!-- App posture (migrated from INFOPLIST_KEY_* build settings) -->
	<key>LSApplicationCategoryType</key>
	<string>public.app-category.developer-tools</string>
	<!-- Menubar/no-Dock app (was INFOPLIST_KEY_LSUIElement=1) -->
	<key>LSUIElement</key>
	<true/>
	<key>LSBackgroundOnly</key>
	<false/>
	<key>NSHumanReadableCopyright</key>
	<string></string>
	<key>NSPrincipalClass</key>
	<string>NSApplication</string>

	<!-- DIST-01: single smart "Open in Flint" Services entry (D-01).
	     NSMessage MUST equal the @objc selector base name in FlintServiceProvider.
	     NSPortName MUST equal CFBundleName. Read-only service: NSReturnTypes omitted. -->
	<key>NSServices</key>
	<array>
		<dict>
			<key>NSMenuItem</key>
			<dict>
				<key>default</key>
				<string>Open in Flint</string>
			</dict>
			<key>NSMessage</key>
			<string>openInFlint</string>
			<key>NSPortName</key>
			<string>Flint</string>
			<key>NSSendTypes</key>
			<array>
				<string>public.plain-text</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
